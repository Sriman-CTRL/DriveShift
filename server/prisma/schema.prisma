generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       ConnectedAccount[]
  migrationJobs  MigrationJob[]
}

model ConnectedAccount {
  id             String   @id @default(cuid())

  provider       String
  providerUserId String

  accessToken    String?
  refreshToken   String?
  tokenExpiry    DateTime?
  createdAt      DateTime @default(now())

  userId         String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceMigrations MigrationJob[] @relation("SourceAccount")
  destMigrations   MigrationJob[] @relation("DestAccount")

  @@unique([provider, providerUserId])
}

enum MigrationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model MigrationJob {
  id                  String          @id @default(cuid())

  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceAccountId     String
  sourceAccount       ConnectedAccount @relation("SourceAccount", fields: [sourceAccountId], references: [id])

  destAccountId       String
  destAccount         ConnectedAccount @relation("DestAccount", fields: [destAccountId], references: [id])

  sourceFileId        String
  sourceFileName      String?
  sourceFileMimeType  String?

  destFileId          String?         // set after successful upload

  status              MigrationStatus @default(PENDING)
  errorMessage        String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}